#Theatre capacity = 350 tickets only
total = 350
total_bookings = 0
total_tickets_sold = 0
rejected_bookings = 0
remaining_seats = 350
while remaining_seats >= 0:
  each_booking = int(input("Enter no.of tickets you want between 1 to 15: "))
  if each_booking == 0:
    print(f"Total Bookings: {total_bookings}, Total Tickets Sold: {total_tickets_sold}, Rejected Bookings: {rejected_bookings}, Remaining Seats: {remaining_seats}")
    break
  while each_booking > 15:
    print("you can able to book 1 to 15 tickets at a time only.")
    each_booking = int(input("Enter no.of tickets you want between 1 to 15: "))

  for i in range(1,each_booking+1):
    age = int(input(f"Enter {i} person age: "))
    if age<=12:
      rejected_bookings += 1
      print("BOOKING REJECTED - Age restriction")
      break
  else:  
    total_bookings += 1
    total_tickets_sold += each_booking
    remaining_seats -= total_tickets_sold
